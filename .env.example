# URL pública do site (canônica, sem barra final). Obrigatória em produção.
# No cliente Next.js faz inline de variáveis NEXT_PUBLIC_* no **build** — no Docker/Railway
# configure-as também como variáveis de **build** ao usar Dockerfile.
NEXT_PUBLIC_SITE_URL=https://www.aion.eng.br

# Opcional — métricas anónimas (Plausible). Vazio = sem banner nem script.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Opcional — Plausible self-hosted; omita para usar plausible.io/js/script.js
# NEXT_PUBLIC_PLAUSIBLE_SCRIPT_SRC=https://plausible.seudominio.com/js/script.js

# Runtime (servidor): já definido pelo host; não precisa localmente.
# NODE_ENV=production
